# Autobot runtime environment (baked defaults for the appliance image).
# The first-run web wizard writes AI provider/model choices via the API; you normally don't edit this.
# Robot SECRETS (EBO_LICENSE/UID/AUTHKEY/IDENTITY/TOKEN + vendor/) are provisioned at runtime by the
# collector (mDNS), never baked into the image.

AUTOBOT_ROBOT_LINK=native
EBO_DIR=/opt/ebo
AUTOBOT_HOST=0.0.0.0
AUTOBOT_PORT=8200
AUTOBOT_MEMORY_DIR=/opt/autobot/data/memory
AUTOBOT_FACES_DIR=/opt/autobot/data/faces
EBO_TALK=1

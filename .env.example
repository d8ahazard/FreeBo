# Copy to .env and fill in. Do NOT commit .env. The collector can write the robot-secret block for you.
# This single file configures the whole unified app (there is no separate bridge/brain anymore).

# ============================ Robot link mode ============================
# native = drive the real robot (Pi, needs the secrets below). mock = hardware-free dev (PC, no secrets).
AUTOBOT_ROBOT_LINK=native

# ============================ Web server ============================
AUTOBOT_HOST=0.0.0.0
AUTOBOT_PORT=8200

# ============================ AI provider (OpenAI-compatible) ============================
# Usually set via the first-run web wizard instead of here.
# AUTOBOT_AI_PROVIDER selects the brain architecture:
#   openai|openrouter|ollama|lmstudio|groq|custom = a single OpenAI-compatible (vision) model is the brain.
#   vlm    = a local vision model (scripts/vlm_service.py) both sees AND decides (no tools/memory).
#   hybrid = REFLEX + CORTEX: the VLM is the EYES (perceives the scene) and the OpenAI-compatible model
#            below is the CORTEX (tool-calling: memory, talking, curiosity, places, HA, MCP). Recommended.
AUTOBOT_AI_PROVIDER=openai       # openai|openrouter|ollama|lmstudio|groq|custom|vlm|hybrid
AUTOBOT_AI_BASE_URL=https://api.openai.com/v1
AUTOBOT_AI_API_KEY=
AUTOBOT_AI_MODEL=gpt-4o-mini     # FAST model used every interaction tick (the CORTEX in hybrid mode)
AUTOBOT_AI_SUMMARIZER_MODEL=     # HEAVY model for once-a-day memory cleanup (blank = use the fast model)
# AUTOBOT_SETUP_COMPLETE=true     # set by the wizard; leave unset for first-run onboarding

# ---- Reflex + Cortex (hybrid) tuning. Only used when AUTOBOT_AI_PROVIDER=hybrid. ----
AUTOBOT_VLM_URL=http://127.0.0.1:8360   # the VLM "eyes" service (scripts/vlm_service.py)
AUTOBOT_CAPTION_SECONDS=2.0      # how often the VLM re-perceives the scene for the cortex
AUTOBOT_REFLEX_STOP_CM=18        # ToF reflex: stop if an obstacle is closer than this (cm); 0 disables

# ============================ Behavior (user-only; the AI cannot change these) ============================
AUTOBOT_AUTONOMY=manual          # manual | assist | auto  (start safe)
AUTOBOT_MAX_SPEED=0.6            # 0..1 hard speed clamp
AUTOBOT_TICK_SECONDS=4.0
AUTOBOT_REQUIRE_CALIBRATION=true # gate autonomous roaming until movement is calibrated (POST /api/calibrate)
# Behavior: it OBSERVES by default and only roams for a reason (sees you -> greet; idle a while -> patrol).
# AUTOBOT_IDLE_PATROL_SECONDS=180  # idle this long with nobody around -> take a short patrol roam
# AUTOBOT_PATROL_SECONDS=30        # how long a patrol excursion lasts before settling back to observe
# AUTOBOT_GREET_SECONDS=12         # how long it will approach/greet a newly-seen person
AUTOBOT_TALK_ENABLED=false       # allow the robot to speak (default off)
# AUTOBOT_GOAL=Gently explore your surroundings...

# ============================ Persona / identity / authority ============================
AUTOBOT_NAME=Autobot             # the name it answers to
AUTOBOT_OWNER=                   # your name (the 'maker'); used for pairing + obedience
# AUTOBOT_PERSONA=You are a loyal companion robot, a cross between Jarvis and a friendly dog...
AUTOBOT_REQUIRE_NAME=false       # only act on heard speech that addresses it by name
AUTOBOT_OBEY_OWNER_ONLY=false    # non-owner commands need owner approval (needs face recog to know who's who)

# ============================ Memory + skills ============================
AUTOBOT_MEMORY_DIR=data/memory   # where long-term facts / daily notes / sightings are stored
AUTOBOT_FACES_DIR=data/faces     # enrolled face embeddings (recognition skill)
# Face recognition backend: auto (insightface, then face_recognition) | insightface | face_recognition | none
# AUTOBOT_FACE_BACKEND=auto
# AUTOBOT_FACE_GPU=0             # insightface on CUDA (1) vs CPU (0). CPU is plenty for periodic face scans.
# AUTOBOT_FACE_SIM=0.35         # insightface cosine match threshold (higher = stricter)
# Optional SEMANTIC recall: set a local embedding model (uses the cortex base_url/key by default) to make
# `recall` use meaning-based similarity instead of keyword match. Blank = keyword recall.
# AUTOBOT_EMBED_MODEL=nomic-embed-text
# AUTOBOT_EMBED_BASE_URL=          # defaults to AUTOBOT_AI_BASE_URL
# AUTOBOT_DAILY_KEEP_DAYS=21       # daily note files older than this are pruned during summarization

# ---- Voice input (optional STT). Needs: pip install faster-whisper ----
AUTOBOT_STT_MODEL=base.en        # whisper model (tiny.en|base.en|small.en|...; .en = English-only, more accurate)
# AUTOBOT_STT_DEVICE=cpu         # cpu | cuda (cuda needs spare VRAM but kills STT backlog/drops)
# AUTOBOT_STT_COMPUTE=int8       # int8 (cpu) | float16 (cuda)
# AUTOBOT_STT_RMS=900            # energy-VAD threshold (higher = ignore more background noise)
# AUTOBOT_STT_MIN_SPEECH=0.4     # min seconds of speech before we transcribe (drops clicks/coughs)
# AUTOBOT_STT_HANG=0.7           # trailing silence (s) that ends an utterance
# AUTOBOT_STT_MAX_UTT=12.0       # hard cap on a single utterance (s)
# AUTOBOT_STT_QUEUE=6            # max queued utterances before dropping the oldest
# AUTOBOT_MIC_GAIN=4             # gain applied to the decoded Air 2 mic before VAD/STT (8 clips loud speech)

# ---- Home Assistant skill (let the AI control your smart home). Optional. ----
HASS_BASE_URL=                   # e.g. http://homeassistant.local:8123
HASS_TOKEN=                      # a long-lived access token (HA -> Profile -> Security)

# ---- MCP servers (expose external Model Context Protocol tools to the cortex). Optional; needs `pip
#      install mcp`. JSON object of {server_id: spec}. spec = {url|command, ...}. authority owner|anyone. ----
# AUTOBOT_MCP_SERVERS={"home_assistant":{"url":"http://homeassistant.local:8123/mcp_server/sse","headers":{"Authorization":"Bearer <token>"},"authority":"owner"}}

# ============================ Robot credentials (device-specific; captured once by the collector) ============================
# Only needed when AUTOBOT_ROBOT_LINK=native. These live ONLY here + in vendor/ (gitignored). Never logged.
EBO_LICENSE=
EBO_UID=
EBO_AUTHKEY=
EBO_IDENTITY=
EBO_TOKEN=

# ============================ Stream auth (mediamtx RTSP/WebRTC/HLS) ============================
EBO_STREAM_USER=ebo
EBO_STREAM_PASS=change-me-rtsp

# ============================ Talkback + audio (native mode) ============================
EBO_TALK=1                       # 1 = allow the robot to speak (outbound audio)
EBO_SNAPSHOT_FPS=2               # frames/sec written for the AI's vision snapshot
# EBO_AUDIO=1                    # mux the robot mic into the stream (off by default for lowest latency)
# EBO_AUDIO_FMT=alaw             # switch if distorted

# ============================ Eye-animation param (refine with autobot/robot/native/probe_eyes.py) ============================
EBO_EYE_GROUP=display
EBO_EYE_KEY=expression

# ============================ Optional Home Assistant MQTT (native mode) ============================
EBO_MQTT_HOST=
EBO_MQTT_PORT=1883
EBO_MQTT_USER=
EBO_MQTT_PASS=

# ============================ Optional device info for diagnostics ============================
EBO_NAME=EBO-SE
EBO_ROBOT_IP=192.168.1.42
